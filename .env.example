# ============================================================
# maimaiDX QueryBot 统一配置
# 查询、账号绑定、B50 上传、PC 与 BREAK 均在本插件内配置。
# 复制为 Bot 根目录的 .env 或 .env.prod 后填写。
# ============================================================

# ---------- QueryBot 必填 ----------
MAIMAIDXPATH=/absolute/path/to/static
MAIMAIDXTOKEN=diving_fish_developer_token

# ---------- AWMC 账号 / 上传服务 ----------
# team：自建 sw-api；public：AWMC 公共网关。
AWMC_API_MODE=team
AWMC_API_BASE_URL=http://127.0.0.1:5001
AWMC_PUBLIC_GATEWAY_TOKEN=
AWMC_API_TIMEOUT_SECONDS=120
AWMC_API_RETRY_COUNT=3
AWMC_API_RETRY_DELAY_SECONDS=1
AWMC_UPLOAD_POLL_INTERVAL_SECONDS=3
AWMC_UPLOAD_POLL_TIMEOUT_SECONDS=600
AWMC_ACCOUNT_ENABLED=true
# 二维码缓存秒数；0=永久，重新 mai绑定 时更新。
AWMC_QRCODE_CACHE_SECONDS=0

# ---------- 管理审计 / WebUI ----------
# WebUI 默认独立监听 8099；启用或修改端口后需重启 Bot。
MAIMAIDX_ADMIN_WEB_ENABLED=false
# 至少 24 位高强度随机字符串，只通过 Authorization: Bearer 发送。
MAIMAIDX_ADMIN_WEB_TOKEN=replace_with_a_long_random_secret
# 独立 WebUI 监听地址/端口。本机反代推荐 127.0.0.1；Docker 跨容器可用 0.0.0.0。
MAIMAIDX_ADMIN_WEB_HOST=127.0.0.1
MAIMAIDX_ADMIN_WEB_PORT=8099
MAIMAIDX_ADMIN_WEB_PATH=/maimaidx/admin
# 用于「管理面板」指令展示完整地址，例如 https://bot.example.com
MAIMAIDX_ADMIN_WEB_PUBLIC_URL=
MAIMAIDX_AUDIT_RETENTION_DAYS=90
MAIMAIDX_MESSAGE_STATS_ENABLED=true
# 默认开启：合并连续回复，并省略可有可无的“处理中”提示。
MAIMAIDX_COMPACT_MESSAGES=true
MAIMAIDX_USER_AGREEMENT_REQUIRED=true
# 超级管理员迁移指令只允许读取该目录中的 Koishi 数据库/映射文件。
MAIMAIDX_KOISHI_MIGRATION_DIR=data/migration

# ---------- 统一数据存储：sqlite / yaml / mysql ----------
MAIMAIDX_STORAGE_BACKEND=sqlite
MAIMAIDX_STORAGE_NAMESPACE=default
MAIMAIDX_STORAGE_YAML_PATH=data/storage/state.yaml
MAIMAIDX_STORAGE_MYSQL_HOST=
MAIMAIDX_STORAGE_MYSQL_PORT=3306
MAIMAIDX_STORAGE_MYSQL_USER=
MAIMAIDX_STORAGE_MYSQL_PASSWORD=
MAIMAIDX_STORAGE_MYSQL_DATABASE=
MAIMAIDX_STORAGE_MYSQL_CHARSET=utf8mb4
MAIMAIDX_STORAGE_MYSQL_TABLE_PREFIX=maimaidx_
MAIMAIDX_STORAGE_MYSQL_SSL=false
MAIMAIDX_STORAGE_MYSQL_KEEP_SNAPSHOTS=3
MAIMAIDX_STORAGE_SYNC_INTERVAL_SECONDS=60
MAIMAIDX_STORAGE_INCLUDE_USER_SCORES=true
# auto=同一后端沿用本地缓存；remote=每次启动强制从持久化后端恢复。
MAIMAIDX_STORAGE_BOOTSTRAP_POLICY=auto
# 默认禁止在空 YAML/MySQL 上直接启动，要求先走管理员迁移。
MAIMAIDX_STORAGE_ALLOW_EMPTY_REMOTE_INIT=false
# true=配置、连接或校验失败时拒绝启动，防止误用旧数据。
MAIMAIDX_STORAGE_FAIL_FAST=true

# team 模式机台参数。旧变量 SDGBTECHAPI 仍兼容，但推荐使用上面的统一 URL。
SDGBT_CLIENT_ID=your_keychip
SDGBT_REGION_ID=1
SDGBT_PLACE_ID=1403
SDGBT_REGION_NAME=北京
SDGBT_PLACE_NAME=默认机台

# ---------- 落雪查分查询（与“落雪导入 Token”不同） ----------
LXNS_DEV_TOKEN=
LX_CLIENT_ID=
LX_CLIENT_SECRET=
LX_REDIRECT_URI=

# ---------- 曲库与缓存 ----------
MAIMAIDX_DATA_SOURCE=
MAIMAIDX_DXDATA_PATH=dxdata.json
MAIMAIDX_MUSIC_CACHE_SECONDS=3600
MAIMAIDX_PLAYER_CACHE_SECONDS=900
MAIMAIDX_PLAYER_CACHE_USE_STORAGE=true
MAIMAIDX_PLAYER_STORAGE_FALLBACK_SECONDS=86400
MAIMAIDX_RATING_CACHE_SECONDS=900
MAIMAIDX_FRIEND_BATTLE_CACHE_SECONDS=604800
MAIMAIDX_FRIEND_BATTLE_COOLDOWN_SECONDS=180

# ---------- 平台 ----------
MAIMAIDX_PLATFORM=onebot
MAIMAIDX_USE_QQ_CARD=false
MAIMAIDX_BOT_ADMINS=

# ---------- 谱面标签 / 印象 ----------
DXRATING_TOKEN=
DXRATING_COMBINED_TAGS_URL=https://derrakuma.dxrating.net/functions/v1/combined-tags
PMYX_API_BASE_URL=http://103.45.162.66:37913

# ---------- B50 LLM 分析 ----------
B50_LLM_URL=https://api.openai.com/v1
B50_LLM_KEY=
B50_LLM_MODEL=gemini-3-flash-preview
B50_ASSETS_PATH=

# ---------- 其它 ----------
BOTNAME=maimai
MAIMAIDXPROBERPROXY=false
MAIMAIDXALIASPROXY=false
MAIMAIDXALIASPUSH=true
SAVEINMEM=true
